HOST=127.0.0.1
PORT=8787

# Local admin account used by POST /api/v1/auth/login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_DISPLAY_NAME=Probe Admin

# Optional static bearer token accepted by protected endpoints.
ADMIN_TOKEN=change-this-token

# Used to sign login tokens and encrypt stored Emby passwords.
APP_SECRET=replace-with-a-long-random-secret

DATA_PATH=./data/store.json
CORS_ORIGIN=*
PROBE_TIMEOUT_MS=8000
REFRESH_INTERVAL_MS=300000
ALLOW_PRIVATE_EMBY_URLS=true
PUBLIC_WRITE_API=true
